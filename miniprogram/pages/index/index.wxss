.container { padding: 24rpx; background: #f4f6fb; min-height: 100vh; }
.card { background: white; border-radius: 16rpx; padding: 20rpx; margin-bottom: 20rpx; }
.title { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; }
.picker { padding: 14rpx; border: 1rpx solid #dbe2f0; border-radius: 10rpx; margin-bottom: 12rpx; }
.note { width: 100%; height: 120rpx; border: 1rpx solid #dbe2f0; border-radius: 10rpx; padding: 10rpx; margin-bottom: 12rpx; }
